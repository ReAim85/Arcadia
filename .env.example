# Database — Neon Postgres (Vercel Marketplace)
DATABASE_URL="postgres://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# Vercel — for deploying agents
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# Encryption — for storing user Vercel tokens (32-byte hex key)
ENCRYPTION_KEY=""

# Next.js
NEXTAUTH_SECRET=""

# Security
# Secret key for health check authentication (Vercel cron job header)
CRON_SECRET="your-cron-secret-here"

# Allowed domain for deployed agents (for demo test security)
ALLOWED_DEPLOYMENT_DOMAIN="your-domain.com"

# Rate limiting (in seconds)
HEALTH_CHECK_RATE_LIMIT_WINDOW=60
HEALTH_CHECK_RATE_LIMIT_MAX_REQUESTS=30
